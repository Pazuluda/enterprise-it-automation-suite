# Chemins non secrets du Centre de mise à jour EITAS Identity.

EITAS_IDENTITY_UPDATE_STATUS_FILE="/var/lib/eitas/identity-update/status.json"
EITAS_IDENTITY_UPDATE_SOURCE_CHECK_REQUEST_FILE="/var/lib/eitas/identity-update/requests/upstream-check.json"

# Fournisseurs OIDC explicitement autorisés.
# Format : issuer|jwks_url,issuer|jwks_url
EITAS_IDENTITY_UPDATE_OIDC_PROVIDERS="https://10.10.10.11:62443/auth/realms/eitas|https://10.10.10.11:62443/auth/realms/eitas/protocol/openid-connect/certs,https://10.10.10.11:62443/identity-preprod/realms/eitas|https://10.10.10.11:62443/identity-preprod/realms/eitas/protocol/openid-connect/certs,https://10.10.10.11:62443/identity-candidate/realms/eitas|https://10.10.10.11:62443/identity-candidate/realms/eitas/protocol/openid-connect/certs"
EITAS_IDENTITY_UPDATE_OIDC_ALLOWED_AZP="account-console"
